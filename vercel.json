{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "destination": "/zoe.novak.ga",
      "permanent": false
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "header",
          "key": "x-forwarded-proto",
          "value": "http"
        }
      ],
      "destination": "https://link.gramflow.link/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/yuki.kimura.japan",
      "destination": "/yuki.kimura.japan/index.html"
    },
    {
      "source": "/yuki.kimura.japan/:path*",
      "destination": "/yuki.kimura.japan/:path*"
    },
    {
      "source": "/zoe.novak.ga",
      "destination": "/zoe.novak.ga/index.html"
    },
    {
      "source": "/zoe.novak.ga/:path*",
      "destination": "/zoe.novak.ga/:path*"
    },
    {
      "source": "/Lola_Winslow",
      "destination": "/Lola_Winslow/index.html"
    },
    {
      "source": "/Lola_Winslow/:path*",
      "destination": "/Lola_Winslow/:path*"
    },
    {
      "source": "/nova.sinclair",
      "destination": "/nova.sinclair/index.html"
    },
    {
      "source": "/nova.sinclair/:path*",
      "destination": "/nova.sinclair/:path*"
    },
    {
      "source": "/mika.japanese.kobayashi",
      "destination": "/mika.japanese.kobayashi/index.html"
    },
    {
      "source": "/mika.japanese.kobayashi/:path*",
      "destination": "/mika.japanese.kobayashi/:path*"
    },
    {
      "source": "/japanese.aiko.nakamura",
      "destination": "/japanese.aiko.nakamura/index.html"
    },
    {
      "source": "/japanese.aiko.nakamura/:path*",
      "destination": "/japanese.aiko.nakamura/:path*"
    },
    {
      "source": "/emi.japanese.mori",
      "destination": "/emi.japanese.mori/index.html"
    },
    {
      "source": "/emi.japanese.mori/:path*",
      "destination": "/emi.japanese.mori/:path*"
    },
    {
      "source": "/maryna.divchyna.ukranian",
      "destination": "/maryna.divchyna.ukranian/index.html"
    },
    {
      "source": "/maryna.divchyna.ukranian/:path*",
      "destination": "/maryna.divchyna.ukranian/:path*"
    },
    {
      "source": "/opheliavoss",
      "destination": "/opheliavoss/index.html"
    },
    {
      "source": "/opheliavoss/:path*",
      "destination": "/opheliavoss/:path*"
    },
    {
      "source": "/honeydewiris",
      "destination": "/honeydewiris/index.html"
    },
    {
      "source": "/honeydewiris/:path*",
      "destination": "/honeydewiris/:path*"
    },
    {
      "source": "/maevesterling",
      "destination": "/maevesterling/index.html"
    },
    {
      "source": "/maevesterling/:path*",
      "destination": "/maevesterling/:path*"
    },
    {
      "source": "/shimizu.japanese.vixen",
      "destination": "/shimizu.japanese.vixen/index.html"
    },
    {
      "source": "/shimizu.japanese.vixen/:path*",
      "destination": "/shimizu.japanese.vixen/:path*"
    },
    {
      "source": "/yana.ukrainska.goddess",
      "destination": "/yana.ukrainska.goddess/index.html"
    },
    {
      "source": "/yana.ukrainska.goddess/:path*",
      "destination": "/yana.ukrainska.goddess/:path*"
    },
    {
      "source": "/ukrainian.olena.beauty",
      "destination": "/ukrainian.olena.beauty/index.html"
    },
    {
      "source": "/ukrainian.olena.beauty/:path*",
      "destination": "/ukrainian.olena.beauty/:path*"
    },
    {
      "source": "/zoenovakga",
      "destination": "/zoenovakga/index.html"
    },
    {
      "source": "/zoenovakga/:path*",
      "destination": "/zoenovakga/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://connect.facebook.net https://*.vercel-insights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://www.google-analytics.com https://stats.g.doubleclick.net https://*.facebook.com https://*.vercel-insights.com; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests;"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"
        }
      ]
    },
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/(.*).css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).jpg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).webp",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
